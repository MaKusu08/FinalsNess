<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Admin Panel{% endblock %}</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * {
    box-sizing: border-box;
}

/* ===== GLOBAL ===== */
body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(145deg, #0b0b0b, #141414);
    color: #ffffff;
    display: flex;
    min-height: 100vh;
}

/* ===== SIDEBAR ===== */
.sidebar {
    width: 250px;
    background: linear-gradient(180deg, #ffa600, #ff8c00);
    height: 100vh;
    position: fixed;
    left: 0;
    top: 0;
    padding: 30px 20px;
    box-shadow: 4px 0 30px rgba(0,0,0,0.6);
    display: flex;
    flex-direction: column;
}

.sidebar .logo {
    text-align: center;
    margin-bottom: 25px;
}

.sidebar .logo img {
    width: 150px;
    filter: drop-shadow(0 5px 10px rgba(0,0,0,0.4));
}

/* ===== MENU ===== */
.menu {
    margin-top: 20px;
}

.menu a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    margin-bottom: 12px;
    border-radius: 12px;
    text-decoration: none;
    color: #2b2b2b;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.25s ease;
    background: rgba(255,255,255,0.15);
}

.menu a:hover {
    background: #000;
    color: #ffa600;
    transform: translateX(6px);
}

.menu a.active {
    background: #000;
    color: #ffa600;
    font-weight: 600;
    box-shadow: 0 8px 20px rgba(0,0,0,0.5);
}

/* ===== MAIN CONTENT ===== */
.content {
    margin-left: 250px;
    padding: 40px;
    width: calc(100% - 250px);
}

/* ===== PAGE TITLES ===== */
h1 {
    font-size: 2.2rem;
    color: #ffa600;
    margin-bottom: 25px;
}

h2 {
    font-size: 1.4rem;
    color: #ffa600;
    margin-bottom: 15px;
}

/* ===== DASHBOARD CARDS ===== */
.stats,
.cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 25px;
    margin-bottom: 40px;
}

.card {
    background: linear-gradient(145deg, #1b1b1b, #141414);
    padding: 25px;
    border-radius: 18px;
    text-align: center;
    box-shadow: 0 15px 35px rgba(0,0,0,0.6);
    transition: transform .3s ease, box-shadow .3s ease;
}

.card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 45px rgba(0,0,0,0.8);
}

.card h2 {
    font-size: 2.4rem;
    margin: 0;
    color: #ffa600;
}

.card p {
    margin-top: 6px;
    font-size: 0.85rem;
    color: #aaa;
}

/* ===== TABLE CARD ===== */
.table-card {
    background: linear-gradient(145deg, #1b1b1b, #121212);
    border-radius: 18px;
    padding: 25px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.7);
    margin-bottom: 40px;
}

/* ===== TABLE ===== */
table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 15px;
}

th, td {
    padding: 14px;
    text-align: left;
    font-size: 0.85rem;
}

th {
    background: #0f0f0f;
    color: #ffa600;
    font-weight: 600;
    border-bottom: 1px solid #333;
}

td {
    border-bottom: 1px solid #222;
    color: #ddd;
}

tr:hover td {
    background: rgba(255,166,0,0.06);
}

/* ===== BADGES ===== */
.badge {
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.pending {
    background: #ff9800;
    color: #000;
}

.paid {
    background: #4caf50;
    color: #000;
}

.unpaid {
    background: #f44336;
    color: #fff;
}

/* ===== BUTTONS ===== */
.action-btn,
.links a {
    display: inline-block;
    margin-top: 12px;
    padding: 10px 20px;
    background: #ffa600;
    color: #000;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: all .3s ease;
}

.action-btn:hover,
.links a:hover {
    background: #000;
    color: #ffa600;
    box-shadow: 0 8px 25px rgba(0,0,0,0.7);
}

/* ===== EMPTY STATES ===== */
.log-empty {
    text-align: center;
    padding: 20px;
    color: #888;
    font-size: 0.85rem;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
    .sidebar {
        width: 200px;
    }

    .content {
        margin-left: 200px;
        padding: 30px;
    }
}

@media (max-width: 700px) {
    body {
        flex-direction: column;
    }

    .sidebar {
        position: relative;
        width: 100%;
        height: auto;
    }

    .content {
        margin-left: 0;
        width: 100%;
    }
}
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
       

        <div class="logo">
            <img src="{{ asset('images/image-removebg-preview.png') }}" alt="Logo">
        </div>

        <nav class="menu">


    {# STAFF #}

    {% if is_granted('ROLE_STAFF') %}
    <a href="{{ path('staff_profile') }}">My Profile</a>
    {% endif %}

    {# ADMIN + STAFF #}

    <a href="{{ path('admin_dashboard') }}"
       class="{{ app.request.get('_route') starts with 'app_admin_dashboard' ? 'active' : '' }}">
        Dashboard
    </a>

    <a href="{{ path('app_admin_movies_index') }}"
       class="{{ app.request.get('_route') starts with 'app_admin_movies' ? 'active' : '' }}">
        Movies
    </a>

    <a href="{{ path('app_admin_rooms_index') }}"
       class="{{ app.request.get('_route') starts with 'app_admin_rooms' ? 'active' : '' }}">
        Rooms
    </a>

    
    {# ADMIN ONLY #}
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('admin_users') }}"
           class="{{ app.request.get('_route') starts with 'admin_users' ? 'active' : '' }}">
            Users
        </a>
    {% endif %}

    {# ADMIN ONLY #}
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_admin_reservations_index') }}"
           class="{{ app.request.get('_route') starts with 'app_admin_reservations' ? 'active' : '' }}">
            Reservations
        </a>

        <a href="{{ path('admin_logs') }}"
           class="{{ app.request.get('_route') starts with 'admin_logs' ? 'active' : '' }}">
            Activity Logs
        </a>
    {% endif %}

    <a href="{{ path('logout') }}">
        Logout
    </a>

</nav>
    </aside>

    <!-- CONTENT -->
    <main class="content">
        {% block body %}{% endblock %}
    </main>

</body>
</html>
