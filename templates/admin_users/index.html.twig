{% extends 'base2.html.twig' %}

{% block title %}User Management{% endblock %}

{% block body %}
<style>
    body {
        background: #0f0f0f;
        color: #fff;
        font-family: 'Poppins', sans-serif;
    }

    .page-container {
        max-width: 1100px;
        margin: 40px auto;
        padding: 20px;
    }

    h1 {
        color: #ffa600;
        margin-bottom: 25px;
        text-align: center;
    }

    .btn-create {
        background: #ffa600;
        color: #000;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
        margin-bottom: 20px;
        display: inline-block;
    }

    .btn-create:hover {
        background: #000;
        color: #ffa600;
        border: 1px solid #ffa600;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        background: #1e1e1e;
        border-radius: 12px;
        overflow: hidden;
    }

    th, td {
        padding: 14px;
        text-align: left;
        font-size: 0.9rem;
    }

    th {
        background: #111;
        color: #ffa600;
        font-weight: 600;
    }

    tr:nth-child(even) {
        background: #2a2a2a;
    }

    tr:hover {
        background: #262626;
    }

    .badge {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        display: inline-block;
    }

    .active { background: #4caf50; color: #000; }
    .disabled { background: #f44336; color: #fff; }

    .actions a {
        margin-right: 6px;
        padding: 6px 12px;
        font-size: 0.75rem;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        color: #fff;
        transition: 0.3s;
    }

    .actions a.edit { background: #2196f3; }
    .actions a.delete { background: #f44336; }

    .actions a.edit:hover { background: #1976d2; }
    .actions a.delete:hover { background: #d32f2f; }

    .empty {
        text-align: center;
        padding: 20px;
        color: #888;
    }
</style>

<div class="page-container">
    <h1>User Management</h1>

    <a href="{{ path('admin_users_create') }}" class="btn-create">➕ Create User</a>

    <table>
        <thead>
            <tr>
                <th>Username</th>
                <th>Roles</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.username }}</td>
                <td>{{ user.roles|join(', ') }}</td>
                <td>
                    <span class="badge {{ user.isActive ? 'active' : 'disabled' }}">
                        {{ user.isActive ? 'Active' : 'Disabled' }}
                    </span>
                </td>
                <td>{{ user.createdAt|date('Y-m-d') }}</td>
                <td class="actions">
                    <a href="{{ path('admin_users_edit', {id: user.id}) }}" class="edit">Edit</a>
                    <a href="{{ path('admin_users_delete', {id: user.id}) }}"
                       class="delete"
                       onclick="return confirm('Are you sure?')">Delete</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="empty">No users found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
