<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login | Lumière Entertainment</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #0f0f0f, #1a1a1a);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }

        .login-container {
            background: #ffa600;
            padding: 40px 35px;
            border-radius: 18px;
            width: 100%;
            max-width: 400px;
            text-align: center;
            box-shadow: 0 0 35px rgba(255, 166, 0, 0.35);
            animation: fadeIn 0.6s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .logo {
            margin-bottom: 20px;
        }

        .logo img {
            width: 120px;
        }

        h1 {
            color: #000;
            margin-bottom: 25px;
            font-size: 1.6rem;
            font-weight: 600;
        }

        .error {
            background: #ff4d4d;
            color: #fff;
            padding: 10px;
            border-radius: 8px;
            font-size: 0.9rem;
            margin-bottom: 15px;
        }

        label {
            display: block;
            color: #000;
            text-align: left;
            font-size: 0.85rem;
            margin-bottom: 5px;
            font-weight: 500;
        }

        input {
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            border: none;
            margin-bottom: 18px;
            font-size: 0.95rem;
            background: #2a2a2a;
            color: #fff;
        }

        input::placeholder {
            color: #aaa;
        }

        input:focus {
            outline: none;
            box-shadow: 0 0 0 2px #b47b2b;
        }

        button {
            background: #b47b2b;
            color: #fff;
            border: none;
            padding: 13px;
            width: 100%;
            border-radius: 10px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        button:hover {
            background: #000;
            color: #ffa600;
        }

        @media (max-width: 480px) {
            .login-container {
                padding: 30px 25px;
            }
        }
    </style>
</head>

<body>

<div class="login-container">

    <div class="logo">
        <img src="{{ asset('images/image-removebg-preview.png') }}" alt="Logo">
    </div>



    {% if error %}
        <div class="error">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    <form action="{{ path('login') }}" method="post">
        <label for="username">Username</label>
        <input
            type="text"
            id="username"
            name="_username"
            value="{{ last_username }}"
            placeholder="Enter your username"
            required
        >

        <label for="password">Password</label>
        <input
            type="password"
            id="password"
            name="_password"
            placeholder="Enter your password"
            required
        >

        <button type="submit">Login</button>
    </form>

</div>

</body>
</html>