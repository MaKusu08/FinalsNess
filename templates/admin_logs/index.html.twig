{% extends 'base2.html.twig' %}

{% block title %}Activity Logs{% endblock %}

{% block body %}
<style>
    body {
        background: #0f0f0f;
        color: #fff;
        font-family: 'Poppins', sans-serif;
    }

    .container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 25px;
    }

    h1 {
        color: #ffa600;
        margin-bottom: 20px;
    }

    /* FILTER BAR */
    .filters {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
    }

    .filters input,
    .filters select {
        padding: 10px;
        border-radius: 6px;
        border: none;
        background: #1e1e1e;
        color: #fff;
    }

    .filters button {
        background: #ffa600;
        border: none;
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: bold;
        cursor: pointer;
    }

    /* TABLE */
    table {
        width: 100%;
        border-collapse: collapse;
        background: #1a1a1a;
        border-radius: 10px;
        overflow: hidden;
    }

    th, td {
        padding: 12px 15px;
        text-align: left;
    }

    th {
        background: #222;
        color: #ffa600;
        font-size: 0.9rem;
        text-transform: uppercase;
    }

    tr:nth-child(even) {
        background: #151515;
    }

    tr:hover {
        background: #242424;
    }

    .badge {
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: bold;
    }

    .login { background: #4caf50; }
    .create { background: #2196f3; }
    .update { background: #ff9800; }
    .delete { background: #f44336; }
    .logout { background: #9c27b0; }
</style>

<div class="container">
    <h1>Activity Logs</h1>

    <!-- FILTERS -->
    <form method="get" class="filters">
        <input type="text" name="user" placeholder="Username" value="{{ app.request.get('user') }}">
        
        <select name="action">
            <option value="">All Actions</option>
            <option value="LOGIN">Login</option>
            <option value="LOGOUT">Logout</option>
            <option value="CREATE">Create</option>
            <option value="UPDATE">Update</option>
            <option value="DELETE">Delete</option>
        </select>

        <input type="date" name="date">
        <button type="submit">Filter</button>
    </form>

    <!-- LOG TABLE -->
    <table>
        <thead>
            <tr>
                <th>User</th>
                <th>Role</th>
                <th>Action</th>
                <th>Date & Time</th>
            </tr>
        </thead>
        <tbody>
        {% for log in logs %}
            <tr>
                <td>{{ log.username }}</td>
                <td>{{ log.role }}</td>
                <td>
                    <span class="badge {{ log.action|lower }}">
                        {{ log.action }}
                    </span>
                </td>
                <td>{{ log.createdAt|date('Y-m-d H:i:s') }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" style="text-align:center; padding: 20px;">
                    No activity logs found.
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
