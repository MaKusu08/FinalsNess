<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Welcome to Lumière Entertainment</title>
    <style>
        body {
            font-family: 'Poppins', Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 0;
        }
        .container {
            max-width: 600px;
            margin: 40px auto;
            background: #ffffff;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }
        .header {
            background: #ffa600;
            padding: 30px;
            text-align: center;
        }
        .header img {
            max-width: 150px;
        }
        .content {
            padding: 40px 30px;
            text-align: center;
        }
        .button {
            display: inline-block;
            background: #b47b2b;
            color: #ffffff;
            padding: 12px 30px;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            margin: 20px 0;
        }
        .footer {
            background: #f8f8f8;
            padding: 20px;
            text-align: center;
            font-size: 12px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <img src="{{ absolute_url(asset('images/image-removebg-preview.png')) }}" alt="Lumière Entertainment">
        </div>
        <div class="content">
            <h2>Welcome {{ username }}!</h2>
            <p>Thank you for joining <strong>Lumière Entertainment</strong>.</p>
            <p>Your account has been successfully created using Google Login.</p>
            <p>You now have access to your staff dashboard.</p>
            
            <a href="{{ absolute_url(path('staff_dashboard')) }}" class="button">Go to Dashboard</a>
        </div>
        <div class="footer">
            <p>&copy; {{ "now"|date("Y") }} Lumière Entertainment. All rights reserved.</p>
        </div>
    </div>
</body>
</html>