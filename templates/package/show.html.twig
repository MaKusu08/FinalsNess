{% extends 'base2.html.twig' %}

{% block title %}Package Details{% endblock %}

{% block body %}

<h1>Package Details</h1>

<div class="table-card">

    <h2 style="color:#ffa600;">{{ package.name }}</h2>

    <p><strong>Description:</strong> {{ package.description }}</p>

    <p><strong>Price:</strong> <span class="badge paid">₱{{ package.price }}</span></p>

    <p><strong>Type:</strong> <span class="badge pending">{{ package.type }}</span></p>

    <br>

    <a href="{{ path('app_package_index') }}" class="action-btn">
        Back
    </a>

    <a href="{{ path('app_package_edit', {'id': package.id}) }}" class="action-btn">
        Edit
    </a>

    {{ include('package/_delete_form.html.twig') }}

</div>

{% endblock %}