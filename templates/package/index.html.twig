{% extends 'base2.html.twig' %}

{% block title %}Package Management{% endblock %}

{% block body %}

<h1>Package Management</h1>

<div class="table-card">

    <div style="display:flex; justify-content:space-between; align-items:center;">
        <h2 style="margin:0;">All Packages</h2>

        <a href="{{ path('app_package_new') }}" class="action-btn">
            + Create Package
        </a>
    </div>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Type</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
        {% for package in packages %}
            <tr>
                <td>{{ package.id }}</td>

                <td style="color:#ffa600; font-weight:600;">
                    {{ package.name }}
                </td>

                <td>
                    {{ package.description|length > 50
                        ? package.description|slice(0, 50) ~ '...'
                        : package.description }}
                </td>

                <td>
                    <span class="badge paid">
                        ₱{{ package.price }}
                    </span>
                </td>

                <td>
                    <span class="badge pending">
                        {{ package.type }}
                    </span>
                </td>

                <td>
                    <a class="action-btn"
                       href="{{ path('app_package_show', {'id': package.id}) }}">
                        View
                    </a>

                    <a class="action-btn"
                       href="{{ path('app_package_edit', {'id': package.id}) }}">
                        Edit
                    </a>

                    {{ include('package/_delete_form.html.twig') }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="log-empty">
                    No packages found
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

</div>

{% endblock %}