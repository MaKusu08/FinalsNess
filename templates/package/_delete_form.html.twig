<form method="post"
      action="{{ path('app_package_delete', {'id': package.id}) }}"
      onsubmit="return confirm('Are you sure you want to delete this package?');"
      style="display:inline-block; margin-top:10px;">

    <input type="hidden"
           name="_token"
           value="{{ csrf_token('delete' ~ package.id) }}">

    <button type="submit"
            class="action-btn"
            style="
                background:#f44336;
                color:#fff;
                border:none;
                cursor:pointer;
            ">
        Delete
    </button>

</form>
