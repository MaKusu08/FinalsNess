{% extends 'base2.html.twig' %}

{% block title %}Manage Movies{% endblock %}

{% block body %}
<style>
    body {
        margin: 0;
        font-family: 'Poppins', sans-serif;
        background: #0f0f0f;
        color: #fff;
    }

    .page-wrapper {
        padding: 40px;
    }

    h1 {
        color: #ffa600;
        margin-bottom: 20px;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .btn {
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-primary {
        background: #ffa600;
        color: #000;
    }

    .btn-primary:hover {
        background: #000;
        color: #ffa600;
        border: 1px solid #ffa600;
    }

    .btn-secondary {
        background: #2a2a2a;
        color: #fff;
        margin-right: 5px;
    }

    .btn-secondary:hover {
        background: #ffa600;
        color: #000;
    }

    .table-container {
        background: #1a1a1a;
        border-radius: 12px;
        padding: 20px;
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #333;
    }

    th {
        color: #ffa600;
        font-weight: 600;
    }

    td img {
        width: 60px;
        height: auto;
        border-radius: 6px;
    }

    .empty {
        text-align: center;
        color: #aaa;
        padding: 20px;
    }
</style>

<div class="page-wrapper">
    <div class="top-bar">
        <h1>🎬 Movies Management</h1>
        <a href="{{ path('app_admin_movies_new') }}" class="btn btn-primary">
            + Add New Movie
        </a>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Movie</th>
                    <th>Description</th>
                    <th>Image</th>
                    <th>Duration</th>
                    <th>Price</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for admin_movie in admin_movies %}
                <tr>
                    <td>{{ admin_movie.id }}</td>
                    <td>{{ admin_movie.MovieName }}</td>
                    <td>{{ admin_movie.MovieDescription|length > 60
                        ? admin_movie.MovieDescription|slice(0, 60) ~ '...'
                        : admin_movie.MovieDescription
                    }}</td>
                    <td>
                        {% if admin_movie.MovieImage %}
                            <img src="{{ asset('uploads/movies/' ~ admin_movie.MovieImage) }}">
                        {% else %}
                            —
                        {% endif %}
                    </td>
                    <td>{{ admin_movie.MovieDuration }} mins</td>
                    <td>₱{{ admin_movie.MoviePrice }}</td>
                    <td>

                        <a href="{{ path('app_admin_movies_edit', {'id': admin_movie.id}) }}"
                           class="btn btn-secondary">Edit</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="empty">No movies found</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
