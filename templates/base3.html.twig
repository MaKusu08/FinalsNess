<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>{% block title %}Lumière Entertainment{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body>

    {# ── Flash Messages ── #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash--{{ type }}">
                {{ message }}
                <button class="flash-close" onclick="this.parentElement.remove()">✕</button>
            </div>
        {% endfor %}
    {% endfor %}

    {# ── Navigation with updated routes ── #}
    <nav>
        <a href="{{ path('home') }}" class="nav-logo">
            <em>Lumière</em> Entertainment
        </a>
        
        <button class="nav-hamburger" aria-label="Menu" onclick="toggleMenu()">
            <span></span><span></span><span></span>
        </button>
        
        <ul class="nav-links">
            <li><a href="{{ path('app_about') }}">About</a></li>
            <li><a href="{{ path('app_rooms') }}">Rooms</a></li>
            <li><a href="{{ path('app_packages') }}">Packages</a></li>
            <li><a href="{{ path('app_team') }}">Team</a></li>
            <li><a href="{{ path('app_contact') }}">Contact</a></li>
            <li><a href="{{ path('login') }}" class="nav-login-btn">🔑 Sign In</a></li>
        </ul>
        
        <a href="{{ path('app_contact') }}" class="nav-cta">Book Now</a>
    </nav>

    {# ── Main Content ── #}
    {% block body %}{% endblock %}

    {# ── Footer with updated routes ── #}
    <footer>
        <div class="contacts-top">
            <div class="contacts-brand">
                <a href="{{ path('home') }}" class="nav-logo" style="display:inline-block">
                    <em>Lumière</em> Entertainment
                </a>
                <p>Where every frame is felt — Private Cinema Experiences in Cebu.</p>
                <div class="social-links">
                    <a href="#" class="social-link">ig</a>
                    <a href="#" class="social-link">fb</a>
                    <a href="#" class="social-link">tw</a>
                </div>
            </div>
            <div class="contacts-col">
                <h5>Explore</h5>
                <ul>
                    <li><a href="{{ path('app_about') }}">About Us</a></li>
                    <li><a href="{{ path('app_rooms') }}">Our Rooms</a></li>
                    <li><a href="{{ path('app_packages') }}">Packages</a></li>
                    <li><a href="{{ path('app_team') }}">Team</a></li>
                </ul>
            </div>
            <div class="contacts-col">
                <h5>Support</h5>
                <ul>
                    <li><a href="#">FAQ</a></li>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Service</a></li>
                    <li><a href="{{ path('app_contact') }}">Contact</a></li>
                </ul>
            </div>
            <div class="contacts-col">
                <h5>Legal</h5>
                <ul>
                    <li><a href="#">© 2024 Lumière</a></li>
                    <li><a href="#">All Rights Reserved</a></li>
                </ul>
            </div>
        </div>
        <div class="contacts-bottom">
            <span>Lumière Entertainment — Private Cinema Experience</span>
            <span>Est. 2025 · Dumaguete City</span>
        </div>
    </footer>

    <script>
        function toggleMenu() {
            const navLinks = document.querySelector('.nav-links');
            const hamburger = document.querySelector('.nav-hamburger');
            navLinks.classList.toggle('open');
            hamburger.classList.toggle('open');
        }

        setTimeout(() => {
            document.querySelectorAll('.flash').forEach(flash => flash.remove());
        }, 5000);
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>