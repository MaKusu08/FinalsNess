{% extends 'base2.html.twig' %}

{% block title %}Change Password{% endblock %}

{% block body %}
<style>
    .password-wrapper {
        max-width: 480px;
        margin: 60px auto;
        background: #1e1e1e;
        padding: 35px;
        border-radius: 14px;
        box-shadow: 0 0 25px rgba(0,0,0,0.6);
    }

    .password-wrapper h1 {
        text-align: center;
        color: #ffa600;
        margin-bottom: 25px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    label {
        display: block;
        font-size: 0.85rem;
        margin-bottom: 6px;
        color: #bbb;
    }

    input[type="password"] {
        width: 100%;
        padding: 12px 14px;
        border-radius: 10px;
        border: 1px solid #333;
        background: #111;
        color: #fff;
        font-size: 0.9rem;
        outline: none;
    }

    input[type="password"]:focus {
        border-color: #ffa600;
        box-shadow: 0 0 8px rgba(255,166,0,0.4);
    }

    .btn {
        width: 100%;
        padding: 12px;
        border-radius: 25px;
        background: #ffa600;
        color: #000;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: 0.3s;
        margin-top: 10px;
    }

    .btn:hover {
        background: #ffb733;
    }

    .alert {
        padding: 12px 15px;
        border-radius: 10px;
        font-size: 0.85rem;
        margin-bottom: 15px;
    }

    .alert-danger {
        background: #ff4d4d;
        color: #000;
    }

    .alert-success {
        background: #4caf50;
        color: #000;
    }

    .hint {
        margin-top: 15px;
        font-size: 0.75rem;
        color: #888;
        text-align: center;
    }
</style>

<div class="password-wrapper">
    <h1>Change Password</h1>

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <form method="post">
        <div class="form-group">
            <label>Current Password</label>
            <input type="password" name="current_password" required>
        </div>

        <div class="form-group">
            <label>New Password</label>
            <input type="password" name="new_password" required>
        </div>

        <button class="btn">Update Password</button>
    </form>

    <p class="hint">
        Make sure your new password is strong and secure.
    </p>
</div>
{% endblock %}