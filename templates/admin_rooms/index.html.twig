{% extends 'base2.html.twig' %}

{% block title %}Admin Rooms{% endblock %}

{% block body %}
<style>
    body {
        background: #0f0f0f;
        color: #fff;
        font-family: 'Poppins', sans-serif;
    }

    .page-container {
        max-width: 1100px;
        margin: 40px auto;
        padding: 30px;
    }

    h1 {
        color: #ffa600;
        margin-bottom: 25px;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .btn-add {
        background: #ffa600;
        color: #000;
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-add:hover {
        background: #000;
        color: #ffa600;
        border: 1px solid #ffa600;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        background: #1e1e1e;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 0 15px rgba(0,0,0,0.6);
    }

    thead {
        background: #111;
    }

    th, td {
        padding: 14px 16px;
        text-align: left;
    }

    th {
        color: #ffa600;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
    }

    td {
        border-bottom: 1px solid #333;
        color: #ddd;
    }

    tr:hover {
        background: rgba(255, 166, 0, 0.05);
    }

    .status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
    }

    .status.available {
        background: rgba(0, 200, 0, 0.2);
        color: #4cff4c;
    }

    .status.unavailable {
        background: rgba(255, 0, 0, 0.2);
        color: #ff6b6b;
    }

    .actions a {
        margin-right: 8px;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-show {
        background: #2a2a2a;
        color: #ffa600;
        border: 1px solid #ffa600;
    }

    .btn-edit {
        background: #ffa600;
        color: #000;
    }

    .btn-show:hover {
        background: #ffa600;
        color: #000;
    }

    .btn-edit:hover {
        background: #000;
        color: #ffa600;
        border: 1px solid #ffa600;
    }

    .empty {
        text-align: center;
        padding: 20px;
        color: #999;
    }
</style>

<div class="page-container">

    <div class="top-bar">
        <h1>🎬 Cinema Rooms</h1>
        <a href="{{ path('app_admin_rooms_new') }}" class="btn-add">+ Add Room</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Room Name</th>
                <th>Capacity</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for admin_room in admin_rooms %}
            <tr>
                <td>{{ admin_room.id }}</td>
                <td>{{ admin_room.RoomName }}</td>
                <td>{{ admin_room.Capacity }}</td>
                <td>
                    <span class="status {{ admin_room.Status == 'Available' ? 'available' : 'unavailable' }}">
                        {{ admin_room.Status }}
                    </span>
                </td>
                <td class="actions">
                    <a href="{{ path('app_admin_rooms_show', {'id': admin_room.id}) }}" class="btn-show">Show</a>
                    <a href="{{ path('app_admin_rooms_edit', {'id': admin_room.id}) }}" class="btn-edit">Edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="empty">No rooms found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

</div>
{% endblock %}
