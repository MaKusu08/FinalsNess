<style>
    .form-group {
        margin-bottom: 18px;
    }

    label {
        display: block;
        margin-bottom: 6px;
        font-size: 0.9rem;
        color: #ccc;
    }

    input, select, textarea {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: none;
        background: #2a2a2a;
        color: #fff;
        font-size: 0.95rem;
    }

    input:focus, select:focus, textarea:focus {
        outline: none;
        box-shadow: 0 0 5px #ffa600;
    }

    .btn-submit {
        margin-top: 25px;
        background: #ffa600;
        color: #000;
        border: none;
        padding: 12px 28px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn-submit:hover {
        background: #000;
        color: #ffa600;
        border: 1px solid #ffa600;
    }
</style>

{{ form_start(form) }}

    {% for field in form %}
        {% if field.vars.name != '_token' %}
            <div class="form-group">
                {{ form_label(field) }}
                {{ form_widget(field) }}
                {{ form_errors(field) }}
            </div>
        {% endif %}
    {% endfor %}

    <button class="btn-submit">
        {{ button_label|default('Save') }}
    </button>

    {# CSRF token – hidden, required #}
    {{ form_widget(form._token) }}

{{ form_end(form, { render_rest: false }) }}
