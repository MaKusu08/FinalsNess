{% extends 'base2.html.twig' %}

{% block title %}Admin Reservation{% endblock %}

{% block body %}
<style>
    body {
        margin: 0;
        font-family: 'Poppins', sans-serif;
        background: #0f0f0f;
        color: #fff;
    }

    .page-container {
        padding: 40px;
    }

    h1 {
        color: #ffa600;
        margin-bottom: 25px;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .btn-create {
        background: #ffa600;
        color: #000;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-create:hover {
        background: #000;
        color: #ffa600;
        border: 1px solid #ffa600;
    }

    .card {
        background: #1e1e1e;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 0 15px rgba(0,0,0,0.5);
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
    }

    th, td {
        padding: 14px;
        border-bottom: 1px solid #333;
        text-align: left;
        font-size: 0.9rem;
    }

    th {
        background: #111;
        color: #ffa600;
        font-weight: 600;
    }

    tr:hover {
        background: #262626;
    }

    .badge {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        display: inline-block;
    }

    .paid { background: #4caf50; color: #000; }
    .pending { background: #ff9800; color: #000; }
    .unpaid { background: #f44336; color: #fff; }

    .actions a {
        margin-right: 6px;
        padding: 6px 12px;
        font-size: 0.75rem;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
    }

    .btn-edit { background: #2196f3; color: #fff; }
    .btn-back { background: #9c27b0; color: #fff; }

    .empty {
        text-align: center;
        padding: 20px;
        color: #888;
    }
</style>

<div class="page-container">

    <div class="top-bar">
        <h1>Reservation Details</h1>
        <a href="{{ path('app_admin_reservations_index') }}" class="btn-create">Back to List</a>
    </div>

    <div class="card">
        <table>
            <tbody>
                <tr>
                    <th>ID</th>
                    <td>{{ admin_reservation.id }}</td>
                </tr>
                <tr>
                    <th>Customer</th>
                    <td>{{ admin_reservation.CustomerName }}</td>
                </tr>
                <tr>
                    <th>Contact</th>
                    <td>{{ admin_reservation.ContactNumber }}</td>
                </tr>
                <tr>
                    <th>Date</th>
                    <td>{{ admin_reservation.ReservationDate ? admin_reservation.ReservationDate|date('Y-m-d') : '' }}</td>
                </tr>
                <tr>
                    <th>Time</th>
                    <td>
                        {{ admin_reservation.StartTime ? admin_reservation.StartTime|date('H:i') : '' }}
                        -
                        {{ admin_reservation.EndTime ? admin_reservation.EndTime|date('H:i') : '' }}
                    </td>
                </tr>
                <tr>
                    <th>Guests</th>
                    <td>{{ admin_reservation.Guests }}</td>
                </tr>
                <tr>
                    <th>Total</th>
                    <td>₱{{ admin_reservation.TotalAmount|number_format(2) }}</td>
                </tr>
                <tr>
                    <th>Payment</th>
                    <td>
                        <span class="badge {{ admin_reservation.PaymentStatus|lower }}">
                            {{ admin_reservation.PaymentStatus }}
                        </span>
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="actions" style="margin-top:15px;">
            <a href="{{ path('app_admin_reservations_edit', {'id': admin_reservation.id}) }}" class="btn-edit">Edit</a>
            {{ include('admin_reservations/_delete_form.html.twig') }}
        </div>
    </div>

</div>
{% endblock %}
