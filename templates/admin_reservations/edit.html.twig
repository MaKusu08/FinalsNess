{% extends 'base2.html.twig' %}

{% block title %}Edit Admin Reservation{% endblock %}

{% block body %}
<style>
    body {
        margin: 0;
        font-family: 'Poppins', sans-serif;
        background: #0f0f0f;
        color: #fff;
    }

    .page-container {
        max-width: 700px; /* Smaller width */
        margin: 40px auto; /* Center horizontally with top margin */
        padding: 20px;
    }

    h1 {
        color: #ffa600;
        margin-bottom: 25px;
        text-align: center; /* Center the title */
    }

    .top-bar {
        display: flex;
        justify-content: flex-end; /* Move button to the right */
        margin-bottom: 20px;
    }

    .btn-create {
        background: #ffa600;
        color: #000;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-create:hover {
        background: #000;
        color: #ffa600;
        border: 1px solid #ffa600;
    }

    .card {
        background: #1e1e1e;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 0 15px rgba(0,0,0,0.5);
    }

    .actions {
        margin-top: 15px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .btn-edit { background: #2196f3; color: #fff; }
    .btn-back { background: #9c27b0; color: #fff; }

</style>

<div class="page-container">
    <div class="top-bar">
        <a href="{{ path('app_admin_reservations_index') }}" class="btn-create">Back to List</a>
    </div>

    <div class="card">
        {{ include('admin_reservations/_form.html.twig', {'button_label': 'Update', 'form_class': 'dark-form'}) }}

        <div class="actions">
            {{ include('admin_reservations/_delete_form.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
