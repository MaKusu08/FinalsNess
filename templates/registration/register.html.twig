{% extends 'base.html.twig' %}

{% block title %}Register - Lumière Entertainment{% endblock %}

{% block body %}
<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'Poppins', sans-serif;
        background: linear-gradient(135deg, #0f0f0f, #1a1a1a);
        color: #fff;
        margin: 0;
        padding: 0;
    }

    .register-container {
        background: #ffa600;
        padding: 40px 35px;
        border-radius: 18px;
        width: 100%;
        max-width: 450px;
        text-align: center;
        box-shadow: 0 0 35px rgba(255, 166, 0, 0.35);
        animation: fadeIn 0.6s ease;
        margin: 50px auto;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .logo {
        margin-bottom: 20px;
    }

    .logo img {
        width: 120px;
    }

    h1 {
        color: #000;
        margin-bottom: 25px;
        font-size: 1.6rem;
        font-weight: 600;
    }

    .error {
        background: #ff4d4d;
        color: #fff;
        padding: 10px;
        border-radius: 8px;
        font-size: 0.9rem;
        margin-bottom: 15px;
    }

    .success {
        background: #4CAF50;
        color: #fff;
        padding: 10px;
        border-radius: 8px;
        font-size: 0.9rem;
        margin-bottom: 15px;
    }

    label {
        display: block;
        color: #000;
        text-align: left;
        font-size: 0.85rem;
        margin-bottom: 5px;
        font-weight: 500;
    }

    input, .form-control {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: none;
        margin-bottom: 18px;
        font-size: 0.95rem;
        background: #2a2a2a;
        color: #fff;
    }

    input::placeholder {
        color: #aaa;
    }

    input:focus, .form-control:focus {
        outline: none;
        box-shadow: 0 0 0 2px #b47b2b;
    }

    button, .btn {
        background: #b47b2b;
        color: #fff;
        border: none;
        padding: 13px;
        width: 100%;
        border-radius: 10px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-bottom: 15px;
    }

    button:hover, .btn:hover {
        background: #000;
        color: #ffa600;
    }

    .login-link {
        text-align: center;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid rgba(0, 0, 0, 0.2);
    }

    .login-link p {
        color: #000;
        font-size: 0.9rem;
        margin-bottom: 0;
    }

    .login-link a {
        color: #000;
        text-decoration: none;
        font-weight: 600;
    }

    .login-link a:hover {
        text-decoration: underline;
    }

    .form-text {
        color: #2a2a2a;
        font-size: 0.75rem;
        margin-top: -12px;
        margin-bottom: 12px;
        text-align: left;
    }

    .form-check {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

    .form-check input {
        width: auto;
        margin-bottom: 0;
        margin-top: 0;
    }

    .form-check label {
        margin-bottom: 0;
        font-size: 0.85rem;
    }

    @media (max-width: 480px) {
        .register-container {
            padding: 30px 25px;
            margin: 20px;
        }
    }
</style>

<div class="register-container">
    <div class="logo">
        <img src="{{ asset('images/image-removebg-preview.png') }}" alt="Lumière Entertainment">
    </div>

    <h1>Create Account</h1>

    {% for flash_error in app.flashes('verify_email_error') %}
        <div class="error">
            {{ flash_error }}
        </div>
    {% endfor %}

    {% for flash_success in app.flashes('success') %}
        <div class="success">
            {{ flash_success }}
        </div>
    {% endfor %}

    {{ form_start(registrationForm, {
        'attr': {'novalidate': 'novalidate'}
    }) }}
    
    {{ form_errors(registrationForm) }}
    
    <div class="mb-3">
        {{ form_label(registrationForm.username, 'Username') }}
        {{ form_widget(registrationForm.username, {'attr': {'placeholder': 'Choose a username'}}) }}
        {{ form_errors(registrationForm.username) }}
    </div>
    
    <div class="mb-3">
        {{ form_label(registrationForm.plainPassword.first, 'Password') }}
        {{ form_widget(registrationForm.plainPassword.first, {'attr': {'placeholder': 'Create a password'}}) }}
        {{ form_errors(registrationForm.plainPassword.first) }}
    </div>
    
    <div class="mb-3">
        {{ form_label(registrationForm.plainPassword.second, 'Confirm Password') }}
        {{ form_widget(registrationForm.plainPassword.second, {'attr': {'placeholder': 'Confirm your password'}}) }}
        {{ form_errors(registrationForm.plainPassword.second) }}
    </div>
    
    <div class="form-check">
        {{ form_widget(registrationForm.agreeTerms) }}
        {{ form_label(registrationForm.agreeTerms, 'I agree to the Terms and Conditions') }}
        {{ form_errors(registrationForm.agreeTerms) }}
    </div>
    
    <button type="submit">Register</button>
    
    {{ form_end(registrationForm) }}
    
    <div class="login-link">
        <p>Already have an account? <a href="{{ path('login') }}">Login here</a></p>
    </div>
</div>
{% endblock %}